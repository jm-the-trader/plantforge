# Supabase connection (cloud sync mode).
# Copy this file to `.env` and fill in your project's values.
# Leave BOTH blank to run in local-only mode (data stored in the browser,
# no login required) — handy for trying the app before setting up Supabase.
#
# These are the PUBLIC project URL and ANON key — safe to expose in the client.
# NEVER put the service_role key here or anywhere in the frontend.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
